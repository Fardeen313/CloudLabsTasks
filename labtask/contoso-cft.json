{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Contoso Training Institute - AWS Security Workshop - Windows VM with pre-installed tools",

  "Parameters": {
    "CloudLabsDeploymentID": {
      "Description": "Unique Deployment ID assigned by CloudLabs",
      "Type": "String"
    },
    "VMUserName": {
      "Description": "Windows VM admin username",
      "Type": "String",
      "Default": "LabUser"
    },
    "VMPassword": {
      "Description": "Windows VM admin password",
      "Type": "String",
      "Default": "Password.1!!"
    },
    "ODLID": {
      "Description": "On-Demand Lab ID from CloudLabs",
      "Type": "String"
    },
    "InstallCloudLabsShadow": {
      "Description": "Required by CloudLabs platform",
      "Type": "String",
      "Default": "false"
    }
  },

  "Mappings": {
    "RegionMap": {
      "us-east-1":      { "HVM64": "YOUR-CUSTOM-AMI-ID-US-EAST-1" },
      "us-east-2":      { "HVM64": "YOUR-CUSTOM-AMI-ID-US-EAST-2" },
      "us-west-1":      { "HVM64": "YOUR-CUSTOM-AMI-ID-US-WEST-1" },
      "us-west-2":      { "HVM64": "YOUR-CUSTOM-AMI-ID-US-WEST-2" },
      "ap-south-1":     { "HVM64": "YOUR-CUSTOM-AMI-ID-AP-SOUTH-1" },
      "ap-southeast-1": { "HVM64": "YOUR-CUSTOM-AMI-ID-AP-SOUTHEAST-1" },
      "ap-northeast-1": { "HVM64": "YOUR-CUSTOM-AMI-ID-AP-NORTHEAST-1" },
      "eu-west-1":      { "HVM64": "YOUR-CUSTOM-AMI-ID-EU-WEST-1" },
      "eu-central-1":   { "HVM64": "YOUR-CUSTOM-AMI-ID-EU-CENTRAL-1" }
    }
  },

  "Resources": {

    "LabVPC": {
      "Type": "AWS::EC2::VPC",
      "Properties": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true,
        "Tags": [
          {
            "Key": "Name",
            "Value": { "Fn::Join": [ "", [ "LabVPC-", { "Ref": "CloudLabsDeploymentID" } ] ] }
          }
        ]
      }
    },

    "LabInternetGateway": {
      "Type": "AWS::EC2::InternetGateway",
      "Properties": {
        "Tags": [
          {
            "Key": "Name",
            "Value": { "Fn::Join": [ "", [ "LabIGW-", { "Ref": "CloudLabsDeploymentID" } ] ] }
          }
        ]
      }
    },

    "AttachGateway": {
      "Type": "AWS::EC2::VPCGatewayAttachment",
      "Properties": {
        "VpcId": { "Ref": "LabVPC" },
        "InternetGatewayId": { "Ref": "LabInternetGateway" }
      }
    },

    "LabSubnet": {
      "Type": "AWS::EC2::Subnet",
      "Properties": {
        "VpcId": { "Ref": "LabVPC" },
        "CidrBlock": "10.0.0.0/24",
        "MapPublicIpOnLaunch": true,
        "AvailabilityZone": { "Fn::Sub": "${AWS::Region}a" },
        "Tags": [
          {
            "Key": "Name",
            "Value": { "Fn::Join": [ "", [ "LabSubnet-", { "Ref": "CloudLabsDeploymentID" } ] ] }
          }
        ]
      }
    },

    "LabRouteTable": {
      "Type": "AWS::EC2::RouteTable",
      "Properties": {
        "VpcId": { "Ref": "LabVPC" },
        "Tags": [
          {
            "Key": "Name",
            "Value": { "Fn::Join": [ "", [ "LabRouteTable-", { "Ref": "CloudLabsDeploymentID" } ] ] }
          }
        ]
      }
    },

    "LabRoute": {
      "Type": "AWS::EC2::Route",
      "DependsOn": "AttachGateway",
      "Properties": {
        "RouteTableId": { "Ref": "LabRouteTable" },
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": { "Ref": "LabInternetGateway" }
      }
    },

    "SubnetRouteTableAssociation": {
      "Type": "AWS::EC2::SubnetRouteTableAssociation",
      "Properties": {
        "SubnetId": { "Ref": "LabSubnet" },
        "RouteTableId": { "Ref": "LabRouteTable" }
      }
    },

    "LabSecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupDescription": "Allow RDP and HTTPS for CloudLabs VM access",
        "VpcId": { "Ref": "LabVPC" },
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 3389,
            "ToPort": 3389,
            "CidrIp": "0.0.0.0/0",
            "Description": "RDP access"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "CidrIp": "0.0.0.0/0",
            "Description": "HTTPS for CloudLabs RDP over HTTP"
          }
        ],
        "Tags": [
          {
            "Key": "Name",
            "Value": { "Fn::Join": [ "", [ "LabSG-", { "Ref": "CloudLabsDeploymentID" } ] ] }
          }
        ]
      }
    },

    "LabKeyPair": {
      "Type": "AWS::EC2::KeyPair",
      "Properties": {
        "KeyName": { "Fn::Join": [ "", [ "labkeypair-", { "Ref": "CloudLabsDeploymentID" } ] ] }
      }
    },

    "LabWindowsVM": {
      "Type": "AWS::EC2::Instance",
      "Properties": {
        "ImageId": {
          "Fn::FindInMap": [ "RegionMap", { "Ref": "AWS::Region" }, "HVM64" ]
        },
        "InstanceType": "t3.large",
        "KeyName": { "Ref": "LabKeyPair" },
        "SubnetId": { "Ref": "LabSubnet" },
        "SecurityGroupIds": [ { "Ref": "LabSecurityGroup" } ],
        "UserData": {
          "Fn::Base64": {
            "Fn::Sub": "<powershell>\nRename-LocalUser -Name 'Administrator' -NewName '${VMUserName}'\n$Password = ConvertTo-SecureString '${VMPassword}' -AsPlainText -Force\n$UserAccount = Get-LocalUser -Name '${VMUserName}'\n$UserAccount | Set-LocalUser -Password $Password\n</powershell>"
          }
        },
        "Tags": [
          {
            "Key": "Name",
            "Value": { "Fn::Join": [ "", [ "LabVM-", { "Ref": "CloudLabsDeploymentID" } ] ] }
          }
        ]
      }
    }

  },

  "Outputs": {
    "AWSAccountId": {
      "Description": "Participant AWS Account ID - used as inject key in lab guide",
      "Value": { "Fn::Sub": "${AWS::AccountId}" }
    },
    "VMPublicIP": {
      "Description": "Public IP of the Windows VM",
      "Value": { "Fn::GetAtt": [ "LabWindowsVM", "PublicIp" ] }
    },
    "VMUserName": {
      "Description": "Windows VM username",
      "Value": { "Ref": "VMUserName" }
    },
    "VMPassword": {
      "Description": "Windows VM password",
      "Value": { "Ref": "VMPassword" }
    },
    "DeploymentID": {
      "Description": "CloudLabs Deployment ID",
      "Value": { "Ref": "CloudLabsDeploymentID" }
    }
  }

}
