{
    "AWSTemplateFormatVersion": "2010-09-09",
    "Description": "CloudLabs Windows EC2 Environment with ECS Fargate RDP over HTTPS support",
    "Parameters": {
        "AccessKey": {
            "Description": "Access key to authenticate to AWS account",
            "Type": "String",
            "Default": "GET-ACCESS-KEY"
        },
        "SecretKey": {
            "Description": "Secret key to authenticate to AWS account",
            "Type": "String",
            "Default": "GET-SECRET-KEY"
        },
        "CheckAcknowledgement": {
            "Type": "String",
            "Default": "TRUE"
        },
        "vpcCidr": {
            "Type": "String",
            "Default": "10.10.0.0/16"
        },
        "subnetCidr": {
            "Type": "String",
            "Default": "10.10.0.0/24"
        },
        "clgclusterSubnetCidr": {
            "Type": "String",
            "Default": "10.10.1.0/24"
        },
        "AmazonECSTaskExecutionRolePolicy": {
            "Type": "String",
            "Default": "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy"
        },
        "VMUserName": {
            "Type": "String",
            "Default": "Labuser"
        },
        "VMPassword": {
            "Type": "String",
            "Default": "LabPassword123"
        }
    },
    "Resources": {
        "TaskExecutionRole": {
            "Type": "AWS::IAM::Role",
            "Properties": {
                "AssumeRolePolicyDocument": {
                    "Version": "2012-10-17",
                    "Statement": [
                        {
                            "Effect": "Allow",
                            "Principal": {
                                "Service": [
                                    "ecs-tasks.amazonaws.com"
                                ]
                            },
                            "Action": [
                                "sts:AssumeRole"
                            ]
                        }
                    ]
                },
                "Path": "/",
                "ManagedPolicyArns": [
                    {
                        "Ref": "AmazonECSTaskExecutionRolePolicy"
                    }
                ],
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": "TaskExecutionRole"
                    }
                ]
            }
        },
        "clgVpc": {
            "Type": "AWS::EC2::VPC",
            "Properties": {
                "CidrBlock": {
                    "Ref": "vpcCidr"
                },
                "EnableDnsSupport": true,
                "EnableDnsHostnames": true,
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": "clgVpc"
                    }
                ]
            }
        },
        "clgInternetGateway": {
            "Type": "AWS::EC2::InternetGateway",
            "Properties": {
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": "clgInternetGateway"
                    }
                ]
            }
        },
        "attachInternetGateway": {
            "Type": "AWS::EC2::VPCGatewayAttachment",
            "Properties": {
                "InternetGatewayId": {
                    "Ref": "clgInternetGateway"
                },
                "VpcId": {
                    "Ref": "clgVpc"
                }
            }
        },
        "vmSubnet": {
            "Type": "AWS::EC2::Subnet",
            "Properties": {
                "AvailabilityZone": {
                    "Fn::Sub": "${AWS::Region}a"
                },
                "MapPublicIpOnLaunch": true,
                "VpcId": {
                    "Ref": "clgVpc"
                },
                "CidrBlock": {
                    "Ref": "subnetCidr"
                },
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": "vmSubnet"
                    }
                ]
            }
        },
        "clgClusterSubnet": {
            "Type": "AWS::EC2::Subnet",
            "Properties": {
                "MapPublicIpOnLaunch": true,
                "VpcId": {
                    "Ref": "clgVpc"
                },
                "CidrBlock": {
                    "Ref": "clgclusterSubnetCidr"
                },
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": "clgClusterSubnet"
                    }
                ]
            }
        },
        "RouteTable": {
            "Type": "AWS::EC2::RouteTable",
            "Properties": {
                "VpcId": {
                    "Ref": "clgVpc"
                },
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": "RouteTable"
                    }
                ]
            }
        },
        "routesToInternetGateway": {
            "Type": "AWS::EC2::Route",
            "DependsOn": "attachInternetGateway",
            "Properties": {
                "RouteTableId": {
                    "Ref": "RouteTable"
                },
                "DestinationCidrBlock": "0.0.0.0/0",
                "GatewayId": {
                    "Ref": "clgInternetGateway"
                }
            }
        },
        "vmSubnetRouteTableAssociation": {
            "Type": "AWS::EC2::SubnetRouteTableAssociation",
            "Properties": {
                "SubnetId": {
                    "Ref": "vmSubnet"
                },
                "RouteTableId": {
                    "Ref": "RouteTable"
                }
            }
        },
        "clusterSubnetRouteTableAssociation": {
            "Type": "AWS::EC2::SubnetRouteTableAssociation",
            "Properties": {
                "SubnetId": {
                    "Ref": "clgClusterSubnet"
                },
                "RouteTableId": {
                    "Ref": "RouteTable"
                }
            }
        },
        "vmSecurityGroup": {
            "Type": "AWS::EC2::SecurityGroup",
            "Properties": {
                "GroupDescription": "Allow RDP to client host",
                "VpcId": {
                    "Ref": "clgVpc"
                },
                "SecurityGroupIngress": [
                    {
                        "IpProtocol": "tcp",
                        "FromPort": 3389,
                        "ToPort": 3389,
                        "CidrIp": "0.0.0.0/0"
                    },
                    {
                        "IpProtocol": "tcp",
                        "FromPort": "0",
                        "ToPort": "65535",
                        "CidrIp": {
                            "Ref": "clgclusterSubnetCidr"
                        }
                    }
                ],
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": "vmSecurityGroup"
                    }
                ]
            }
        },
        "clgSg": {
            "Type": "AWS::EC2::SecurityGroup",
            "Properties": {
                "GroupDescription": "Security group for Fargate ECS container",
                "VpcId": {
                    "Ref": "clgVpc"
                },
                "SecurityGroupIngress": [
                    {
                        "FromPort": 443,
                        "ToPort": 443,
                        "IpProtocol": "tcp",
                        "CidrIp": "0.0.0.0/0"
                    },
                    {
                        "FromPort": 443,
                        "ToPort": 443,
                        "IpProtocol": "tcp",
                        "CidrIpv6": "::/0"
                    }
                ],
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": "clgSg"
                    }
                ]
            }
        },
        "vmKeyPair": {
            "Type": "AWS::EC2::KeyPair",
            "Properties": {
                "KeyName": "labkeypair"
            }
        },
        "vmInstance": {
            "Type": "AWS::EC2::Instance",
            "Properties": {
                "ImageId": {
                    "Fn::Sub": "{{resolve:ssm:/aws/service/ami-windows-latest/Windows_Server-2022-English-Full-Base}}"
                },
                "InstanceType": "t3.micro",
                "SecurityGroupIds": [
                    {
                        "Ref": "vmSecurityGroup"
                    }
                ],
                "KeyName": {
                    "Ref": "vmKeyPair"
                },
                "SubnetId": {
                    "Ref": "vmSubnet"
                },
                "UserData": {
                    "Fn::Base64": {
                        "Fn::Sub": "<powershell>\nnet user Administrator \"${VMPassword}\"\nRename-LocalUser -Name \"Administrator\" -NewName \"${VMUserName}\"\n$Password = ConvertTo-SecureString \"${VMPassword}\" -AsPlainText -Force\n$UserAccount = Get-LocalUser -Name \"${VMUserName}\"\n$UserAccount | Set-LocalUser -Password $Password\n\n# Install Chocolatey\nSet-ExecutionPolicy Bypass -Scope Process -Force\n[System.Net.ServicePointManager]::SecurityProtocol = [System.Net.ServicePointManager]::SecurityProtocol -bor 3072\nInvoke-Expression ((New-Object System.Net.WebClient).DownloadString('https://community.chocolatey.org/install.ps1'))\n\n# Install tools via Chocolatey\nchoco install vscode -y\nchoco install brave -y\nchoco install git -y\n\n# Install Power Automate Desktop\n$powerAutomateUrl = 'https://go.microsoft.com/fwlink/?linkid=2102613'\n$powerAutomateInstaller = \"$env:TEMP\\PowerAutomateSetup.exe\"\nInvoke-WebRequest -Uri $powerAutomateUrl -OutFile $powerAutomateInstaller\nStart-Process -FilePath $powerAutomateInstaller -ArgumentList '-Silent' -Wait\n\n# Install Power BI Desktop\n$powerBIUrl = 'https://download.microsoft.com/download/8/8/0/880BCA75-79DD-466A-927D-1ABF1F5454B0/PBIDesktopSetup_x64.exe'\n$powerBIInstaller = \"$env:TEMP\\PBIDesktopSetup_x64.exe\"\nInvoke-WebRequest -Uri $powerBIUrl -OutFile $powerBIInstaller\nStart-Process -FilePath $powerBIInstaller -ArgumentList '-quiet', '-norestart' -Wait\n\n# Install n8n (requires Node.js first)\nchoco install nodejs-lts -y\nRefreshEnv\nnpm install -g n8n\n\n</powershell>\n"
                    }
                },
                "Tags": [
                    {
                        "Key": "Name",
                        "Value": "labvm"
                    }
                ]
            }
        }
    },
    "Outputs": {
        "AWSAccountID": {
            "Description": "AWS Account ID",
            "Value": {
                "Ref": "AWS::AccountId"
            }
        },
        "Region": {
            "Description": "AWS Region",
            "Value": {
                "Ref": "AWS::Region"
            }
        },
        "VpcId": {
            "Description": "The ID of the VPC",
            "Value": {
                "Ref": "clgVpc"
            }
        },
        "vmSubnetId": {
            "Description": "The ID of the VM Subnet",
            "Value": {
                "Ref": "vmSubnet"
            }
        },
        "vmSecurityGroupId": {
            "Description": "The SG ID of the VM",
            "Value": {
                "Ref": "vmSecurityGroup"
            }
        },
        "clusterSubnetId": {
            "Description": "The ID of the Cluster Subnet",
            "Value": {
                "Ref": "clgClusterSubnet"
            }
        },
        "clusterSecurityGroupId": {
            "Description": "The SG ID of the Cluster",
            "Value": {
                "Ref": "clgSg"
            }
        },
        "TaskExecutionRole": {
            "Description": "The ARN of the Role utilised by ECS Task Definition",
            "Value": {
                "Fn::GetAtt": [
                    "TaskExecutionRole",
                    "Arn"
                ]
            }
        },
        "InstanceId": {
            "Description": "EC2 Instance ID",
            "Value": {
                "Ref": "vmInstance"
            }
        },
        "VMName": {
            "Description": "Name of the VM",
            "Value": "labvm"
        },
        "VMPublicIP": {
            "Description": "VM Public IP",
            "Value": {
                "Fn::GetAtt": [
                    "vmInstance",
                    "PublicIp"
                ]
            }
        },
        "VMPrivateIP": {
            "Description": "VM Private IP",
            "Value": {
                "Fn::GetAtt": [
                    "vmInstance",
                    "PrivateIp"
                ]
            }
        },
        "VMPublicDNSName": {
            "Description": "Public DNS Name",
            "Value": {
                "Fn::GetAtt": [
                    "vmInstance",
                    "PublicDnsName"
                ]
            }
        },
        "VMPrivateDNSName": {
            "Description": "Private DNS Name",
            "Value": {
                "Fn::GetAtt": [
                    "vmInstance",
                    "PrivateDnsName"
                ]
            }
        },
        "VMUserName": {
            "Description": "VM Username",
            "Value": {
                "Ref": "VMUserName"
            }
        },
        "VMPassword": {
            "Description": "VM Password",
            "Value": {
                "Ref": "VMPassword"
            }
        }
    }
}