{
	"AWSTemplateFormatVersion": "2010-09-09",
	"Description": "CloudLabs Windows EC2 Environment",
	"Resources": {
		"LabVPC": {
			"Type": "AWS::EC2::VPC",
			"Properties": {
				"CidrBlock": "10.0.0.0/16",
				"EnableDnsSupport": true,
				"EnableDnsHostnames": true,
				"Tags": [
					{
						"Key": "Name",
						"Value": "LabVPC"
					}
				]
			}
		},
		"InternetGateway": {
			"Type": "AWS::EC2::InternetGateway",
			"Properties": {
				"Tags": [
					{
						"Key": "Name",
						"Value": "LabIGW"
					}
				]
			}
		},
		"AttachGateway": {
			"Type": "AWS::EC2::VPCGatewayAttachment",
			"Properties": {
				"VpcId": {
					"Ref": "LabVPC"
				},
				"InternetGatewayId": {
					"Ref": "InternetGateway"
				}
			}
		},
		"PublicSubnet": {
			"Type": "AWS::EC2::Subnet",
			"Properties": {
				"VpcId": {
					"Ref": "LabVPC"
				},
				"CidrBlock": "10.0.1.0/24",
				"MapPublicIpOnLaunch": true,
				"AvailabilityZone": {
					"Fn::Select": [
						0,
						{
							"Fn::GetAZs": ""
						}
					]
				},
				"Tags": [
					{
						"Key": "Name",
						"Value": "LabPublicSubnet"
					}
				]
			}
		},
		"PublicRouteTable": {
			"Type": "AWS::EC2::RouteTable",
			"Properties": {
				"VpcId": {
					"Ref": "LabVPC"
				},
				"Tags": [
					{
						"Key": "Name",
						"Value": "PublicRT"
					}
				]
			}
		},
		"PublicRoute": {
			"Type": "AWS::EC2::Route",
			"DependsOn": "AttachGateway",
			"Properties": {
				"RouteTableId": {
					"Ref": "PublicRouteTable"
				},
				"DestinationCidrBlock": "0.0.0.0/0",
				"GatewayId": {
					"Ref": "InternetGateway"
				}
			}
		},
		"SubnetRouteAssociation": {
			"Type": "AWS::EC2::SubnetRouteTableAssociation",
			"Properties": {
				"SubnetId": {
					"Ref": "PublicSubnet"
				},
				"RouteTableId": {
					"Ref": "PublicRouteTable"
				}
			}
		},
		"LabSecurityGroup": {
			"Type": "AWS::EC2::SecurityGroup",
			"Properties": {
				"GroupDescription": "Allow RDP",
				"VpcId": {
					"Ref": "LabVPC"
				},
				"SecurityGroupIngress": [
					{
						"IpProtocol": "tcp",
						"FromPort": 3389,
						"ToPort": 3389,
						"CidrIp": "0.0.0.0/0"
					}
				]
			}
		},
		"TaskExecutionRole": {
			"Type": "AWS::IAM::Role",
			"Properties": {
				"RoleName": "CloudLabsECSTaskExecutionRole",
				"AssumeRolePolicyDocument": {
					"Version": "2012-10-17",
					"Statement": [
						{
							"Effect": "Allow",
							"Principal": {
								"Service": "ecs-tasks.amazonaws.com"
							},
							"Action": "sts:AssumeRole"
						}
					]
				},
				"ManagedPolicyArns": [
					"arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy"
				]
			}
		},
		"LabInstance": {
			"Type": "AWS::EC2::Instance",
			"Properties": {
				"InstanceType": "t3.micro",
				"SubnetId": {
					"Ref": "PublicSubnet"
				},
				"SecurityGroupIds": [
					{
						"Ref": "LabSecurityGroup"
					}
				],
				"ImageId": {
					"Fn::Sub": "{{resolve:ssm:/aws/service/ami-windows-latest/Windows_Server-2022-English-Full-Base}}"
				},
				"UserData": {
					"Fn::Base64": {
						"Fn::Sub": "<powershell>\nnet user Administrator LabPassword@123\n</powershell>\n"
					}
				},
				"Tags": [
					{
						"Key": "Name",
						"Value": "CloudLabs-Windows-Instance"
					}
				]
			}
		}
	},
	"Outputs": {
		"AWSAccountID": {
			"Description": "AWS Account ID",
			"Value": {
				"Ref": "AWS::AccountId"
			}
		},
		"InstanceId": {
			"Description": "EC2 Instance ID",
			"Value": {
				"Ref": "LabInstance"
			}
		},
		"PublicIP": {
			"Description": "Public IP of Windows Instance",
			"Value": {
				"Fn::GetAtt": [
					"LabInstance",
					"PublicIp"
				]
			}
		},
		"Region": {
			"Description": "AWS Region",
			"Value": {
				"Ref": "AWS::Region"
			}
		},
		"Username": {
			"Description": "RDP Username",
			"Value": "Administrator"
		},
		"DNSName": {
			"Description": "Public DNS Name of Windows Instance",
			"Value": {
				"Fn::GetAtt": [
					"LabInstance",
					"PublicDnsName"
				]
			}
		},
		"VMName": {
			"Description": "VM Name Tag",
			"Value": "CloudLabs-Windows-Instance"
		},
		"Password": {
			"Description": "RDP Password",
			"Value": "LabPassword@123"
		},
		"SecurityGroupId": {
			"Description": "Security Group ID",
			"Value": {
				"Ref": "LabSecurityGroup"
			}
		},
		"SubnetId": {
			"Description": "Subnet ID",
			"Value": {
				"Ref": "PublicSubnet"
			}
		},
		"PrivateIP": {
			"Description": "Private IP of Windows Instance",
			"Value": {
				"Fn::GetAtt": [
					"LabInstance",
					"PrivateIp"
				]
			}
		},
		"TaskExecutionRole": {
			"Description": "ECS Task Execution Role ARN for Fargate RDP proxy",
			"Value": {
				"Fn::GetAtt": [
					"TaskExecutionRole",
					"Arn"
				]
			}
		}
	}
}